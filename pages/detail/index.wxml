<view class="container detail-page">
  <view class="article-head">
    <view class="hero-kicker">ARTICLE</view>
    <view class="article-title">{{title}}</view>
    <view class="article-desc" wx:if="{{description}}">{{description}}</view>
  </view>

  <view class="article surface">
    <block wx:for="{{blocks}}" wx:key="index">
      <view wx:if="{{item.type === 'h1'}}" class="md-h1">{{item.text}}</view>
      <view wx:elif="{{item.type === 'h2'}}" class="md-h2">{{item.text}}</view>
      <view wx:elif="{{item.type === 'h3'}}" class="md-h3">{{item.text}}</view>
      <view wx:elif="{{item.type === 'p'}}" class="md-p">{{item.text}}</view>
      <view wx:elif="{{item.type === 'ul'}}" class="md-list">
        <view wx:for="{{item.items}}" wx:key="index" class="md-li">• {{item}}</view>
      </view>
      <view wx:elif="{{item.type === 'ol'}}" class="md-list">
        <view wx:for="{{item.items}}" wx:key="index" class="md-li">{{index + 1}}. {{item}}</view>
      </view>
    </block>
  </view>

  <view class="article-cta">
    <view class="cta-text">看完还有疑问，就直接去虾聊天继续问。</view>
    <button class="primary-btn" bindtap="goChat">去虾聊天问 AI</button>
  </view>
</view>
