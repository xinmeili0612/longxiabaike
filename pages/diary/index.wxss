@import "../../app.wxss";

.page-with-tabbar {
  padding-bottom: 188rpx;
}

.chips {
  margin-bottom: 24rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.item {
  padding: 30rpx 28rpx 32rpx;
}

.item--featured {
  background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(255,247,235,0.96) 100%);
  box-shadow: 0 18rpx 34rpx rgba(240, 138, 36, 0.1);
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 18rpx;
}

.meta-pill--dark {
  background: rgba(29, 29, 31, 0.88);
  color: #ffffff;
}

.tag {
  color: #a86a1d;
  font-size: 22rpx;
  font-weight: 700;
}

.item-title {
  font-size: 34rpx;
  line-height: 1.34;
  font-weight: 760;
  color: #111827;
  letter-spacing: -0.03em;
}

.item-desc {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.72;
  color: #6e6e73;
}
