@import "../../app.wxss";

.page-with-tabbar {
  padding-bottom: 188rpx;
}

.hero--centered {
  text-align: center;
  align-items: center;
  background: linear-gradient(180deg, rgba(255,248,240,0.96) 0%, rgba(255,244,230,0.88) 100%);
  margin: -28rpx -24rpx 24rpx;
  padding: 28rpx 24rpx 20rpx;
  border-radius: 28rpx 28rpx 0 0;
}

.hero-kicker--lobster {
  background: rgba(255, 255, 255, 0.82);
  color: #d45a4f;
}

.section-title--lobster {
  color: #d4584e;
}

.section-subtitle--centered {
  max-width: 560rpx;
  margin-left: auto;
  margin-right: auto;
}

.chips {
  margin-bottom: 24rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.item {
  padding: 30rpx 28rpx 32rpx;
}

.item--featured {
  background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(255,247,235,0.96) 100%);
  box-shadow: 0 18rpx 34rpx rgba(240, 138, 36, 0.1);
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 18rpx;
}

.meta-pill--dark {
  background: rgba(240, 138, 36, 0.16);
  color: #c46a12;
}

.tag {
  color: #a86a1d;
  font-size: 22rpx;
  font-weight: 700;
}

.item-title {
  font-size: 34rpx;
  line-height: 1.34;
  font-weight: 760;
  color: #111827;
  letter-spacing: -0.03em;
}

.item-desc {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.72;
  color: #6e6e73;
}
