@import "../../app.wxss";

.chips {
  margin-bottom: 24rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.item {
  padding: 28rpx 26rpx 30rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 18rpx;
}

.meta-pill--dark {
  background: rgba(29, 29, 31, 0.88);
  color: #ffffff;
}

.tag {
  color: #a86a1d;
  font-size: 22rpx;
  font-weight: 700;
}

.item-title {
  font-size: 34rpx;
  line-height: 1.34;
  font-weight: 760;
  color: #111827;
  letter-spacing: -0.03em;
}

.item-desc {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.72;
  color: #6e6e73;
}

.item-link {
  margin-top: 22rpx;
  color: #c46a12;
  font-size: 24rpx;
  font-weight: 700;
}
