<view class="container">
  <view class="hero">
    <view class="hero-kicker">REAL NOTES</view>
    <view class="section-title">虾日记</view>
    <view class="section-subtitle">从实战、踩坑到成长，把别人走过的路看明白。</view>
  </view>

  <scroll-view scroll-x class="chip-row chips">
    <view wx:for="{{categories}}" wx:key="*this" class="chip {{activeCategory === item ? 'chip--active' : ''}}" data-category="{{item}}" bindtap="switchCategory">{{item}}</view>
  </scroll-view>

  <view class="list">
    <view wx:for="{{filteredDiaries}}" wx:key="id" class="item soft-card" data-id="{{item.id}}" data-kind="diary" bindtap="openDetail">
      <view class="meta-row">
        <view class="meta-pill meta-pill--dark">{{item.category}}</view>
        <view wx:for="{{item.tags}}" wx:key="*this" class="tag">#{{item}}</view>
      </view>
      <view class="item-title">{{item.title}}</view>
      <view class="item-desc">{{item.description}}</view>
      <view class="item-link">继续阅读</view>
    </view>
  </view>
</view>
