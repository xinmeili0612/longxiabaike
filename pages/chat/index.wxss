@import "../../app.wxss";

.chat-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.hero {
  padding: 32rpx;
}

.quick-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.quick {
  padding: 24rpx 26rpx;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #111827;
}

.chat-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.bubble {
  max-width: 88%;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
}

.bubble--model {
  align-self: flex-start;
  background: #ffffff;
  border: 2rpx solid #f3f4f6;
  color: #111827;
}

.bubble--user {
  align-self: flex-end;
  background: #e07a00;
  color: #ffffff;
}

.composer {
  margin-top: 8rpx;
  padding: 12rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.composer-input {
  flex: 1;
  height: 76rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.send-btn {
  margin: 0;
  width: 140rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 18rpx;
  background: #e07a00;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.send-btn::after {
  border: none;
}
