@import "../../app.wxss";

.page-with-tabbar {
  padding-bottom: 100rpx;
}

.chat-page {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 100rpx);
  min-height: 0;
}

.hero--centered {
  text-align: center;
  align-items: center;
  background: linear-gradient(180deg, rgba(255,240,220,0.98) 0%, rgba(255,235,210,0.95) 100%);
  margin: -28rpx -24rpx 16rpx;
  padding: 28rpx 24rpx 18rpx;
  border-radius: 28rpx 28rpx 0 0;
}

.hero-kicker--lobster {
  display: inline-block;
  margin-bottom: 12rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #d45a4f;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 700;
  letter-spacing: 0.08em;
}

.section-title--lobster {
  color: #d4584e;
}

.section-subtitle--centered {
  max-width: 560rpx;
  margin-left: auto;
  margin-right: auto;
}

.chat-title {
  font-size: 48rpx;
  line-height: 1.15;
  font-weight: 800;
  letter-spacing: -0.04em;
  color: #111827;
}

.chat-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7a7a81;
}

.quick-scroll {
  margin-top: 14rpx;
  margin-bottom: 24rpx;
  white-space: nowrap;
}

.quick-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  padding: 0 24rpx;
  height: 64rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  color: #4b5563;
  font-weight: 600;
}

.chat-stream {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  flex: 1;
  min-height: 0;
  height: 0;
  padding: 6rpx 0 8rpx;
  box-sizing: border-box;
}

.message-row {
  display: flex;
}

.message-row--model {
  justify-content: flex-start;
}

.message-row--user {
  justify-content: flex-end;
}

.bubble {
  max-width: 86%;
  padding: 24rpx 26rpx;
  border-radius: 28rpx;
  font-size: 27rpx;
  line-height: 1.72;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.bubble--model {
  background: rgba(255,255,255,0.9);
  color: #1f2937;
  border-top-left-radius: 12rpx;
}

.bubble--user {
  background: linear-gradient(135deg, #ffb649 0%, #f08a24 100%);
  color: #ffffff;
  border-top-right-radius: 12rpx;
}

.composer-wrap {
  position: sticky;
  bottom: 0;
  margin-top: 2rpx;
  padding-top: 2rpx;
  background: linear-gradient(180deg, rgba(245,245,247,0) 0%, rgba(245,245,247,0.88) 18%, rgba(245,245,247,1) 100%);
}

.composer {
  padding: 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  border-radius: 28rpx;
}

.composer-input {
  flex: 1;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  background: rgba(242, 242, 247, 0.96);
  font-size: 28rpx;
  color: #1f2937;
}

.send-btn {
  margin: 0;
  min-width: 100rpx;
  width: 100rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #ffb649 0%, #f08a24 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 20rpx rgba(240, 138, 36, 0.2);
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-btn::after {
  border: none;
}
