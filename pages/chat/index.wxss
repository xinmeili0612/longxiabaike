@import "../../app.wxss";

.page-with-tabbar {
  padding-bottom: 208rpx;
}

.chat-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.chat-header {
  padding: 6rpx 6rpx 10rpx;
}

.chat-title {
  font-size: 48rpx;
  line-height: 1.15;
  font-weight: 800;
  letter-spacing: -0.04em;
  color: #111827;
}

.chat-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7a7a81;
}

.quick-scroll {
  margin-top: 14rpx;
  margin-bottom: 24rpx;
  white-space: nowrap;
}

.quick-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  padding: 0 24rpx;
  height: 64rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  color: #4b5563;
  font-weight: 600;
}

.chat-stream {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  flex: 1;
  min-height: 460rpx;
}

.message-row {
  display: flex;
}

.message-row--model {
  justify-content: flex-start;
}

.message-row--user {
  justify-content: flex-end;
}

.bubble {
  max-width: 86%;
  padding: 24rpx 26rpx;
  border-radius: 28rpx;
  font-size: 27rpx;
  line-height: 1.72;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.bubble--model {
  background: rgba(255,255,255,0.9);
  color: #1f2937;
  border-top-left-radius: 12rpx;
}

.bubble--user {
  background: linear-gradient(135deg, #ffb649 0%, #f08a24 100%);
  color: #ffffff;
  border-top-right-radius: 12rpx;
}

.composer-wrap {
  position: sticky;
  bottom: 0;
  margin-top: 22rpx;
  padding-top: 10rpx;
  background: linear-gradient(180deg, rgba(245,245,247,0) 0%, rgba(245,245,247,0.88) 18%, rgba(245,245,247,1) 100%);
}

.composer {
  padding: 10rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-radius: 26rpx;
}

.composer-input {
  flex: 1;
  height: 78rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: rgba(242, 242, 247, 0.96);
  font-size: 28rpx;
  color: #1f2937;
}

.send-btn {
  margin: 0;
  min-width: 108rpx;
  width: 108rpx;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #ffb649 0%, #f08a24 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 24rpx rgba(240, 138, 36, 0.18);
}

.send-btn::after {
  border: none;
}
