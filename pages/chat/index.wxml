<view class="container page-with-tabbar chat-page">
  <view class="chat-header">
    <view class="chat-title">虾聊天</view>
    <view class="chat-subtitle">随时问我 OpenClaw、部署、技能和使用问题</view>
  </view>

  <scroll-view scroll-x class="chip-row quick-scroll" enable-flex="true">
    <view wx:for="{{quickPrompts}}" wx:key="*this" class="quick-pill surface" data-text="{{item}}" bindtap="quickAsk">{{item}}</view>
  </scroll-view>

  <view class="chat-stream">
    <view wx:for="{{messages}}" wx:key="index" class="message-row {{item.role === 'user' ? 'message-row--user' : 'message-row--model'}}">
      <view class="bubble {{item.role === 'user' ? 'bubble--user' : 'bubble--model'}}">{{item.text}}</view>
    </view>
  </view>

  <view class="composer-wrap">
    <view class="composer surface">
      <input class="composer-input" placeholder="输入你的问题..." value="{{input}}" bindinput="onInput" confirm-type="send" bindconfirm="sendMessage" />
      <button class="send-btn" bindtap="sendMessage">发送</button>
    </view>
  </view>
</view>
