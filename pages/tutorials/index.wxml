<view class="container page-with-tabbar">
  <view class="hero hero--centered hero--lobster">
    <view class="hero-kicker hero-kicker--lobster">LOBSTER GUIDE</view>
    <view class="section-title section-title--lobster">龙虾百科</view>
    <view class="section-subtitle section-subtitle--centered">给完全小白看的 OpenClaw 内容库，先理解，再上手。</view>
  </view>

  <view class="search-shell surface">
    <input class="search-input" placeholder="搜索百科内容..." value="{{searchQuery}}" bindinput="onSearchInput" />
  </view>

  <scroll-view scroll-x class="chip-row chips">
    <view wx:for="{{categories}}" wx:key="*this" class="chip {{activeCategory === item ? 'chip--active' : ''}}" data-category="{{item}}" bindtap="switchCategory">{{item}}</view>
  </scroll-view>

  <view class="list">
    <view wx:for="{{filteredTutorials}}" wx:key="id" class="item soft-card {{item.featured ? 'item--featured' : ''}}" data-id="{{item.id}}" data-kind="tutorial" bindtap="openDetail">
      <view class="item-top">
        <view class="meta-pill">{{item.category}}</view>
      </view>
      <view class="item-title">{{item.title}}</view>
      <view class="item-desc">{{item.description}}</view>
    </view>
  </view>
</view>
