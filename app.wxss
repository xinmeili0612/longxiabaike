page {
  background: #fdfdfd;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.card {
  background: #fffdf5;
  border: 2rpx solid #fef3c7;
  border-radius: 28rpx;
  box-sizing: border-box;
}

.chip-row {
  white-space: nowrap;
}

.chip {
  display: inline-block;
  margin-right: 16rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  border: 2rpx solid #f3f4f6;
  background: #ffffff;
  color: #4b5563;
  font-size: 26rpx;
  font-weight: 700;
}

.chip--active {
  background: #e07a00;
  color: #ffffff;
  border-color: #e07a00;
}

.section-title {
  font-size: 48rpx;
  line-height: 1.25;
  font-weight: 800;
  color: #111827;
}

.section-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.empty-tip {
  padding: 60rpx 32rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 28rpx;
}
