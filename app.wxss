page {
  background: #f5f5f7;
  color: #1d1d1f;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Helvetica Neue", sans-serif;
}

.container {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.surface {
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.06);
  border-radius: 28rpx;
  box-sizing: border-box;
}

.soft-card {
  background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(255,251,245,0.92) 100%);
  border: 1rpx solid rgba(255,255,255,0.9);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
  border-radius: 28rpx;
  box-sizing: border-box;
}

.hero {
  padding: 18rpx 6rpx 8rpx;
}

.hero-kicker {
  display: inline-block;
  margin-bottom: 16rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #c46a12;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 700;
  letter-spacing: 0.08em;
}

.section-title {
  font-size: 56rpx;
  line-height: 1.12;
  font-weight: 800;
  color: #111827;
  letter-spacing: -0.04em;
}

.section-subtitle {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #6e6e73;
}

.search-shell {
  margin-top: 24rpx;
  margin-bottom: 22rpx;
  padding: 8rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.05);
}

.search-input {
  height: 82rpx;
  padding: 0 26rpx;
  border-radius: 20rpx;
  background: rgba(242, 242, 247, 0.9);
  font-size: 28rpx;
  color: #1d1d1f;
}

.chip-row {
  white-space: nowrap;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  padding: 0 26rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.75);
  color: #6e6e73;
  font-size: 25rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.04);
}

.chip--active {
  background: linear-gradient(135deg, #ffb649 0%, #f08a24 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(240, 138, 36, 0.24);
}

.meta-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 183, 77, 0.14);
  color: #c46a12;
  font-size: 21rpx;
  font-weight: 700;
}

.empty-tip {
  padding: 60rpx 32rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 28rpx;
}

.primary-btn {
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ffb649 0%, #f08a24 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 32rpx rgba(240, 138, 36, 0.24);
}

.primary-btn::after {
  border: none;
}
