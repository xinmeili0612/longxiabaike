<view class="tab-shell">
  <view class="tabbar surface">
    <view class="tab-item {{selected === 0 ? 'tab-item--active' : ''}}" data-index="0" data-path="/pages/tutorials/index" bindtap="switchTab">
      <view class="tab-text tab-text--side">虾百科</view>
    </view>

    <view class="tab-center-wrap">
      <view class="tab-center-shadow"></view>
      <view class="tab-center {{selected === 1 ? 'tab-center--active' : ''}}" data-index="1" data-path="/pages/chat/index" bindtap="switchTab">
        <view class="tab-center-dot"></view>
      </view>
      <view class="tab-center-text {{selected === 1 ? 'tab-center-text--active' : ''}}">虾聊天</view>
    </view>

    <view class="tab-item {{selected === 2 ? 'tab-item--active' : ''}}" data-index="2" data-path="/pages/diary/index" bindtap="switchTab">
      <view class="tab-text tab-text--side">虾日记</view>
    </view>
  </view>
</view>
