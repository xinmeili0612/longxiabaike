@import "../app.wxss";

.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 18rpx;
  display: flex;
  justify-content: center;
  pointer-events: none;
  z-index: 999;
}

.tabbar {
  pointer-events: auto;
  width: calc(100% - 36rpx);
  max-width: 710rpx;
  height: 118rpx;
  padding: 12rpx 26rpx 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  border-radius: 34rpx;
}

.tab-item {
  width: 176rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 10rpx;
  box-sizing: border-box;
}

.tab-text {
  line-height: 1;
  font-weight: 700;
  color: #8e8e93;
}

.tab-text--side {
  font-size: 30rpx;
  letter-spacing: -0.03em;
}

.tab-item--active .tab-text,
.tab-center-text--active {
  color: #c46a12;
}

.tab-center-wrap {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-center-shadow {
  position: absolute;
  top: -10rpx;
  width: 126rpx;
  height: 126rpx;
  border-radius: 63rpx;
  background: rgba(240, 138, 36, 0.16);
  filter: blur(10rpx);
}

.tab-center {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: linear-gradient(135deg, #ffbc57 0%, #f08a24 100%);
  box-shadow: 0 18rpx 34rpx rgba(240, 138, 36, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.tab-center--active {
  transform: scale(1.02);
}

.tab-center-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 0 0 10rpx rgba(255,255,255,0.22);
}

.tab-center-text {
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
  color: #8e8e93;
}
