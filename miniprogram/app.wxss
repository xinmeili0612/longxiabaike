page {
  background: #f5f7fb;
  color: #111827;
  font-family: Arial, Helvetica, sans-serif;
}
.container {
  padding: 24rpx;
}
.card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 12rpx 36rpx rgba(15, 23, 42, 0.06);
  margin-bottom: 24rpx;
}
.card-dark {
  background: linear-gradient(145deg, #0f172a, #172554);
  color: #fff;
}
.title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.35;
}
.subtitle {
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.7;
  margin-top: 12rpx;
}
.card-dark .subtitle { color: rgba(255,255,255,.82); }
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}
.hero {
  background: radial-gradient(circle at top right, rgba(255,114,53,.35), transparent 28%),
              linear-gradient(135deg, #0f172a 5%, #1d4ed8 55%, #ff5a36 110%);
  color: white;
  border-radius: 36rpx;
  padding: 40rpx 28rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}
.hero-kicker {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.14);
  font-size: 22rpx;
  margin-bottom: 16rpx;
}
.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.24;
  margin-bottom: 14rpx;
}
.hero-desc {
  font-size: 26rpx;
  line-height: 1.7;
  opacity: .94;
}
.hero-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}
.hero-btn,
.hero-btn-ghost {
  padding: 18rpx 26rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}
.hero-btn {
  background: #fff;
  color: #111827;
}
.hero-btn-ghost {
  border: 1rpx solid rgba(255,255,255,.35);
  color: #fff;
}
.stat-row {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}
.stat-box {
  flex: 1;
  background: rgba(255,255,255,.12);
  border-radius: 24rpx;
  padding: 20rpx;
}
.stat-num { font-size: 34rpx; font-weight: 800; }
.stat-label { font-size: 22rpx; opacity: .85; margin-top: 6rpx; }
.grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}
.grid-item {
  background: linear-gradient(180deg, #ffffff, #fff6f3);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 1rpx solid #ffe3dc;
}
.grid-item-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}
.grid-item-desc {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff1ee;
  color: #ff5a36;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}
.btn-primary {
  background: linear-gradient(135deg, #ff6a3d, #ff3d6e);
  color: #fff;
  border-radius: 999rpx;
  padding: 24rpx 32rpx;
  text-align: center;
  font-weight: 700;
  margin-top: 20rpx;
}
.list-item { margin-bottom: 18rpx; }
.list-item-title { font-size: 28rpx; font-weight: 700; margin-bottom: 6rpx; }
.list-item-desc { font-size: 24rpx; color: #6b7280; line-height: 1.7; }
.divider-title {
  font-size: 26rpx;
  color: #ff5a36;
  font-weight: 700;
  margin-bottom: 14rpx;
}
.tip-box {
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
  border-radius: 22rpx;
  padding: 22rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #9a3412;
}
