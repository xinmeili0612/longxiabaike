page { background: #f4f7fb; color: #182230; font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif; }
.page { min-height: 100vh; padding: 32rpx 28rpx 44rpx; }
.soft-bg { background:
  radial-gradient(circle at top left, rgba(96, 165, 250, 0.12), transparent 32%),
  radial-gradient(circle at top right, rgba(255, 153, 102, 0.10), transparent 26%),
  linear-gradient(180deg, #f8fbff 0%, #f4f7fb 100%);
}
.hero-block { padding: 40rpx 36rpx; border-radius: 36rpx; background: rgba(255,255,255,0.82); box-shadow: 0 16rpx 40rpx rgba(44, 82, 130, 0.08); backdrop-filter: blur(10px); }
.hero-kicker { display:inline-block; padding: 10rpx 20rpx; background: #eef4ff; color: #2563eb; border-radius: 999rpx; font-size: 22rpx; font-weight: 700; }
.hero-title { margin-top: 22rpx; font-size: 54rpx; font-weight: 800; line-height: 1.12; letter-spacing: -1rpx; }
.hero-desc { margin-top: 16rpx; font-size: 28rpx; line-height: 1.7; color: #607086; }
.search-box { margin-top: 24rpx; }
.search-input { background:#fff; border-radius: 999rpx; padding: 24rpx 30rpx; font-size: 28rpx; box-shadow: 0 12rpx 28rpx rgba(44,82,130,0.06); }
.chip-scroll { margin-top: 24rpx; white-space: nowrap; }
.chip-row { display:flex; gap: 16rpx; }
.chip { flex-shrink: 0; padding: 16rpx 24rpx; border-radius: 999rpx; background: rgba(255,255,255,0.86); color:#5f6f82; font-size: 26rpx; }
.chip-active { background: #111827; color: #fff; }
.list-section { margin-top: 24rpx; display:flex; flex-direction:column; gap: 20rpx; }
.content-card, .detail-card { background:#fff; border-radius: 32rpx; padding: 32rpx; box-shadow: 0 16rpx 40rpx rgba(31, 68, 117, 0.08); }
.content-tag { display:inline-block; padding: 8rpx 18rpx; background:#eef4ff; color:#2563eb; border-radius: 999rpx; font-size: 22rpx; font-weight: 700; }
.content-title, .detail-title { margin-top: 20rpx; font-size: 38rpx; line-height: 1.35; font-weight: 800; }
.content-desc, .detail-intro, .detail-body { margin-top: 14rpx; font-size: 28rpx; line-height: 1.8; color:#5d6d81; }
.section-title { font-size: 34rpx; font-weight: 800; margin-bottom: 18rpx; }
.detail-subtitle { margin-top: 24rpx; font-size: 30rpx; font-weight: 800; color:#111827; }
.related-item { padding: 18rpx 0; font-size: 28rpx; color:#374151; border-bottom: 1rpx solid #edf2f7; }
.related-item:last-child { border-bottom: none; }
.primary-btn { margin-top: 28rpx; text-align:center; padding: 24rpx 28rpx; background: linear-gradient(135deg, #2563eb, #60a5fa); color:#fff; border-radius: 999rpx; font-size: 28rpx; font-weight: 700; }
