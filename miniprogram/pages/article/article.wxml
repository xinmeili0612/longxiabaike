<view class="page soft-bg" wx:if="{{article}}">
  <view class="detail-card">
    <view class="content-tag">{{article.category}}</view>
    <view class="detail-title">{{article.title}}</view>
    <view class="detail-intro">{{article.intro}}</view>
    <view class="detail-body">{{article.content}}</view>
  </view>

  <view class="detail-card">
    <view class="section-title">相关推荐</view>
    <block wx:for="{{article.related}}" wx:key="*this">
      <view class="related-item">{{item}}</view>
    </block>
    <view class="primary-btn" bindtap="goChat">不会？去虾聊天问 AI</view>
  </view>
</view>
