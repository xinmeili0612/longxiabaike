<view class="page soft-bg">
  <view class="hero-block">
    <view class="hero-kicker">虾日记</view>
    <view class="hero-title">别人已经走过的真实路径</view>
    <view class="hero-desc">看案例、看踩坑、看成长，你会更快明白龙虾怎么真正用起来。</view>
  </view>

  <scroll-view scroll-x class="chip-scroll" enable-flex>
    <view class="chip-row">
      <block wx:for="{{tabs}}" wx:key="*this">
        <view class="chip {{activeTab === item ? 'chip-active' : ''}}" data-tab="{{item}}" bindtap="chooseTab">{{item}}</view>
      </block>
    </view>
  </scroll-view>

  <view class="list-section">
    <block wx:for="{{filtered}}" wx:key="id">
      <view class="content-card" data-id="{{item.id}}" bindtap="openDetail">
        <view class="content-tag">{{item.tag}}</view>
        <view class="content-title">{{item.title}}</view>
        <view class="content-desc">{{item.intro}}</view>
      </view>
    </block>
  </view>
</view>
