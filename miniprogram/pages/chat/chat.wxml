<view class="page soft-bg chat-page">
  <view class="hero-block">
    <view class="hero-kicker">虾聊天</view>
    <view class="hero-title">有问题，直接问</view>
    <view class="hero-desc">尽量说人话，少用术语，问完我也会告诉你下一步该干嘛。</view>
  </view>

  <scroll-view scroll-x class="chip-scroll" enable-flex>
    <view class="chip-row">
      <block wx:for="{{quicks}}" wx:key="*this">
        <view class="chip" data-text="{{item}}" bindtap="tapQuick">{{item}}</view>
      </block>
    </view>
  </scroll-view>

  <view class="chat-box">
    <block wx:for="{{messages}}" wx:key="index">
      <view class="msg {{item.role === 'assistant' ? 'msg-ai' : 'msg-user'}}">{{item.text}}</view>
    </block>
  </view>

  <view class="input-bar">
    <input class="chat-input" placeholder="输入你的问题" value="{{input}}" bindinput="onInput" />
    <view class="send-btn" bindtap="submit">发送</view>
  </view>
</view>
