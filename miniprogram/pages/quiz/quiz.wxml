<view class="container">
  <view class="card" wx:if="{{!result}}">
    <view class="title">龙虾路线测试</view>
    <view class="subtitle">回答两个问题，帮你更快找到最适合的入门方向。</view>
  </view>

  <view class="card" wx:if="{{!result}}">
    <view class="divider-title">问题 {{current + 1}}</view>
    <view class="section-title">{{questions[current].title}}</view>
    <block wx:for="{{questions[current].options}}" wx:key="key">
      <view class="grid-item" data-key="{{item.key}}" bindtap="choose" style="margin-bottom: 16rpx;">
        <view class="grid-item-title">{{item.label}}</view>
      </view>
    </block>
  </view>

  <view class="card card-dark" wx:if="{{result}}">
    <view class="title">{{result.title}}</view>
    <view class="subtitle">{{result.desc}}</view>
  </view>

  <view class="card" wx:if="{{result}}">
    <view class="section-title">建议你先做这 3 步</view>
    <block wx:for="{{result.actions}}" wx:key="*this">
      <view class="list-item"><view class="list-item-desc">• {{item}}</view></view>
    </block>
    <view class="btn-primary" bindtap="restart">重新测试</view>
  </view>
</view>
