<view class="page soft-bg">
  <view class="hero-block">
    <view class="hero-kicker">虾教程</view>
    <view class="hero-title">给小白看的龙虾教程</view>
    <view class="hero-desc">一篇只讲一个问题，先学会，再继续往下走。</view>
  </view>

  <view class="search-box">
    <input class="search-input" placeholder="搜索教程，比如：龙虾是什么" bindinput="onSearch" />
  </view>

  <scroll-view scroll-x class="chip-scroll" enable-flex>
    <view class="chip-row">
      <block wx:for="{{categories}}" wx:key="*this">
        <view class="chip {{activeCategory === item ? 'chip-active' : ''}}" data-category="{{item}}" bindtap="chooseCategory">{{item}}</view>
      </block>
    </view>
  </scroll-view>

  <view class="list-section">
    <block wx:for="{{filtered}}" wx:key="id">
      <view class="content-card" data-id="{{item.id}}" bindtap="openDetail">
        <view class="content-tag">{{item.category}}</view>
        <view class="content-title">{{item.title}}</view>
        <view class="content-desc">{{item.intro}}</view>
      </view>
    </block>
  </view>
</view>
